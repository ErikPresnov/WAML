      <ownedRule xmi:type="uml:Constraint" xmi:id="_oH7qIE3-EfGMpb9ZE4qwTg" name="IfSendThenReceive">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_oH9fUE3-EfGMpb9ZE4qwTg" name="constraintSpec">
          <language>OCL</language>
          <body>self.base_Class.clientDependency -> exists(&#xD;
dep | dep.getAppliedStereotypes()->exists(st | st.name = 'Sends') and &#xD;
dep.supplier -> &#xD;
  exists(s | s.getAppliedStereotypes()->exists(st | st.name = 'HTTPRequest'))) &#xD;
implies &#xD;
self.base_Class.clientDependency -> exists(&#xD;
dep | dep.getAppliedStereotypes() -> exists(st | st.name = 'Receives') and &#xD;
dep.supplier -> &#xD;
  exists(s | s.getAppliedStereotypes() -> exists(st | st.name = 'HTTPResponse'))&#xD;
)&#xD;
</body>
        </specification>
      </ownedRule>

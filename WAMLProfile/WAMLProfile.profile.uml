        <specification xmi:type="uml:OpaqueExpression" xmi:id="_Q0cOIE4BEfGMpb9ZE4qwTg" name="constraintSpec">
          <language>OCL</language>
          <body>not self.ComposedOf->includes(self) </body>
        </specification>
